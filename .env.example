# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required for real scoring.
ANTHROPIC_API_KEY=
# Default is the most capable model. For cheaper high-volume runs:
#   MODEL=claude-sonnet-4-6
MODEL=claude-opus-4-8
# Dedicated inbox you'll create for the job hunt (keeps it isolated from personal mail).
APPLICATION_EMAIL=michael.apply.2026@gmail.com
# Only needed if you run Postgres directly (docker-compose sets this for you).
# DATABASE_URL=postgresql+psycopg2://jobfinder:jobfinder@localhost:5432/jobfinder
